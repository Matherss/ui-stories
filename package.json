{
  "name": "ui-stories",
  "version": "0.2.3",
  "type": "module",
  "description": "Lightweight Storybook alternative for Vue / Nuxt projects",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Matherss/ui-stories.git"
  },
  "packageManager": "pnpm@10.33.0",
  "keywords": [
    "vue",
    "nuxt",
    "storybook",
    "stories",
    "components",
    "dev-tools"
  ],
  "main": "./index.js",
  "exports": {
    ".": "./index.js",
    "./module": "./module/index.js"
  },
  "scripts": {
    "build:static": "node bin/build-static.js",
    "preview:static": "node bin/serve-static.js",
    "release": "bumpp"
  },
  "bin": {
    "ui-stories": "bin/serve.js",
    "ui-stories-build": "bin/build-static.js",
    "ui-stories-preview": "bin/serve-static.js"
  },
  "files": [
    "bin",
    "server",
    "module",
    "app",
    "index.js"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher"
    ]
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "fast-glob": "^3.3.3",
    "sass-embedded": "^1.77.6",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^6.3.2",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "bumpp": "^11.0.1"
  }
}
