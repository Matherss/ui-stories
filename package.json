{
  "name": "ui-stories",
  "version": "0.5.5",
  "type": "module",
  "description": "Lightweight Storybook alternative for Vue / Nuxt projects",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Matherss/ui-stories.git"
  },
  "packageManager": "pnpm@10.33.0",
  "keywords": [
    "vue",
    "nuxt",
    "vite",
    "stories",
    "components",
    "dev-tools"
  ],
  "main": "./index.js",
  "exports": {
    ".": "./index.js",
    "./module": "./module/index.js"
  },
  "scripts": {
    "release": "bumpp",
    "stories:dev": "pnpm -C playground stories:dev",
    "stories:build": "pnpm -C playground stories:build"
  },
  "files": [
    "module",
    "runtime",
    "index.js"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher"
    ]
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "sass-embedded": "^1.77.6"
  },
  "devDependencies": {
    "bumpp": "^11.0.1"
  }
}
